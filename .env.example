# This file is a template.
# Copy to `.env` and replace placeholder values with actual values for your environment.

# ====================
# App
# ====================
NODE_ENV=development
PORT=8000

CORS_ORIGINS=http://localhost:3000

ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace_with_secure_secret
# ADMIN_EMAIL=

# ====================
# MySQL
# ====================
MYSQL_ROOT_PASSWORD=replace_with_secure_secret

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=wildfire_db
MYSQL_USER=wildfire
MYSQL_PASSWORD=replace_with_secure_secret

# ====================
# MinIO
# ====================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=replace_with_secure_secret

MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_BUCKET=media
MINIO_REGION=us-east-1
# MINIO_PUBLIC_ENDPOINT=https://example.com

# ====================
# Redis
# ====================
REDIS_URL=redis://localhost:6379

# ====================
# Auth
# ====================
HTSHADOW_PATH=htshadow

JWT_SECRET=replace_with_a_secure_secret_value

INVITE_ACCEPT_BASE_URL=http://localhost:3000/accept-invite
INVITE_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ====================
# Content
# ====================
# CONTENT_MAX_UPLOAD_BYTES=104857600 # 10 MB

# ====================
# Schedules
# ====================
SCHEDULE_TIMEZONE=Asia/Manila # IANA timezone ID

# ====================
# AI
# ====================
AI_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
