# This file is a template.
# Copy to `.env` and replace placeholder values with actual values for your environment.

# ====================
# App
# ====================
NODE_ENV='development'
PORT=8000
CORS_ORIGINS='http://localhost:3000'
ADMIN_USERNAME='admin'
ADMIN_PASSWORD='admin'

# ADMIN_EMAIL=''
# LOG_LEVEL='info'
# LOG_PRETTY=true
# TRUST_PROXY_HEADERS=true
# IDLE_TIMEOUT_MS=0

# ====================
# MySQL
# ====================
MYSQL_HOST='127.0.0.1'
MYSQL_PORT=3306
MYSQL_DATABASE='wildfire_db'
MYSQL_USER='wildfire'
MYSQL_PASSWORD='replace_with_secure_secret'

# Optional:
# MYSQL_ROOT_PASSWORD='replace_with_secure_secret'
# MYSQL_CONNECT_TIMEOUT_MS=10000
# MYSQL_POOL_CONNECTION_LIMIT=10
# MYSQL_POOL_QUEUE_LIMIT=0
# MYSQL_POOL_WAIT_FOR_CONNECTIONS=true
# MYSQL_POOL_IDLE_TIMEOUT_MS=60000
# MYSQL_POOL_MAX_IDLE=10000

# ====================
# MinIO
# ====================
MINIO_ROOT_USER='minioadmin'
MINIO_ROOT_PASSWORD='replace_with_secure_secret'
MINIO_ENDPOINT='localhost'
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_BUCKET='content'
MINIO_REGION='us-east-1'

# Optional:
# MINIO_REQUEST_TIMEOUT_MS=15000

# ====================
# Redis
# ====================
REDIS_URL='redis://localhost:6379'

# Optional:
# REDIS_KEY_PREFIX='wf'
# REDIS_CONNECT_TIMEOUT_MS=10000
# REDIS_COMMAND_TIMEOUT_MS=5000
# REDIS_SOCKET_TIMEOUT_MS=0
# REDIS_RETRY_MAX_ATTEMPTS=20
# REDIS_RETRY_BASE_DELAY_MS=100
# REDIS_RETRY_MAX_DELAY_MS=30000
# REDIS_STREAM_AUDIT_NAME='wf:stream:audit'
# REDIS_STREAM_AUDIT_GROUP='wf-audit-writers'
# REDIS_STREAM_CONTENT_INGEST_NAME='wf:stream:content-ingestion'
# REDIS_STREAM_CONTENT_INGEST_GROUP='wf-content-ingestion-workers'
# REDIS_STREAM_BLOCK_MS=5000
# REDIS_STREAM_BATCH_SIZE=100
# REDIS_STREAM_MAX_DELIVERIES=5
# WORKER_RETRY_BASE_DELAY_MS=250
# WORKER_RETRY_MAX_DELAY_MS=5000
# HEALTH_CHECK_TIMEOUT_MS=1000
# STARTUP_STRICT_STORAGE=false

# ====================
# Auth
# ====================
HTSHADOW_PATH='/etc/htshadow'
JWT_SECRET='replace_with_secure_secret'

# Optional:
# JWT_ISSUER='wildfire'
# AUTH_SESSION_COOKIE_NAME='wildfire_session_token'
# AUTH_LOGIN_RATE_LIMIT_MAX_ATTEMPTS=10
# AUTH_LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
# AUTH_LOGIN_LOCKOUT_THRESHOLD=5
# AUTH_LOGIN_LOCKOUT_SECONDS=300
# INVITE_TOKEN_TTL_SECONDS=86400
# INVITE_ACCEPT_BASE_URL='http://localhost:3000/accept-invite'
# RESET_PASSWORD_BASE_URL='http://localhost:3000/reset-password'
# EMAIL_CHANGE_TOKEN_TTL_SECONDS=86400
# EMAIL_CHANGE_VERIFY_BASE_URL='http://localhost:3000/verify-email-change'

# ====================
# Content
# ====================
# CONTENT_MAX_UPLOAD_BYTES=104857600
# CONTENT_INGEST_QUEUE_CAPACITY=5000
# CONTENT_INGEST_QUEUE_ENQUEUE_MAX_ATTEMPTS=3
# CONTENT_INGEST_QUEUE_ENQUEUE_BASE_DELAY_MS=250
# CONTENT_INGEST_QUEUE_ENQUEUE_MAX_DELAY_MS=4000
# CONTENT_INGEST_QUEUE_ENQUEUE_TIMEOUT_MS=5000
# DEFAULT_EMERGENCY_CONTENT_ID='00000000-0000-0000-0000-000000000000'

# ====================
# Display runtime
# ====================
# DISPLAY_RUNTIME_RATE_LIMIT_WINDOW_SECONDS=60
# DISPLAY_RUNTIME_AUTH_CHALLENGE_MAX_ATTEMPTS=60
# DISPLAY_RUNTIME_AUTH_VERIFY_MAX_ATTEMPTS=60

# ====================
# Schedules
# ====================
# Set the timezone used for schedule window evaluation (IANA timezone ID, e.g. "Asia/Manila").
SCHEDULE_TIMEZONE='Asia/Manila'

# ====================
# Audit
# ====================
# AUDIT_QUEUE_ENABLED=true
# AUDIT_QUEUE_CAPACITY=5000
# AUDIT_QUEUE_ENQUEUE_MAX_ATTEMPTS=3
# AUDIT_QUEUE_ENQUEUE_BASE_DELAY_MS=250
# AUDIT_QUEUE_ENQUEUE_MAX_DELAY_MS=2000
# AUDIT_QUEUE_ENQUEUE_TIMEOUT_MS=5000
# AUDIT_EXPORT_MAX_ROWS=100000

# ====================
# Integration tests
# ====================
# RUN_INTEGRATION=true
